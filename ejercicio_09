#include <iostream>
using namespace std;

int main() {

    double peso, altura;
    cout << "Ingrese su peso (kg): ";
    cin >> peso;
    cout << "Ingrese su altura (m): ";
    cin >> altura;

    double imc = peso / (altura * altura);

    cout << "IMC: " << imc << endl;

    if (imc < 18.5)
        cout << "Bajo peso - Se recomienda mejorar alimentacion\n";
    else if (imc < 25)
        cout << "Normal - Mantener habitos saludables\n";
    else if (imc < 30)
        cout << "Sobrepeso - Se recomienda ejercicio regular\n";
    else if (imc < 35)
        cout << "Obesidad I - Consultar profesional de salud\n";
    else
        cout << "Obesidad II - Evaluacion medica urgente\n";

    return 0;
}
